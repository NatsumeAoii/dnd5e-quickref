{
  "name": "dnd5e-quickref",
  "version": "1.1.6",
  "description": "D&D 5e Quick Reference – Vite + TypeScript",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "sync-version": "node scripts/prebuild.js",
    "prebuild": "npm run sync-version",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "lint:css": "stylelint \"src/**/*.css\" --config config/.stylelintrc.json",
    "audit:data": "node scripts/audit-data.js",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^29.0.1",
    "lightningcss": "^1.32.0",
    "stylelint": "^16.10.0",
    "stylelint-config-standard": "^36.0.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vite-plugin-checker": "^0.12.0",
    "vitest": "^4.1.2"
  }
}
